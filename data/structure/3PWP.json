 "publication": {
  "pmid": "21282516",
  "doi": "10.4049/jimmunol.1003150",
  "title": "Conformational melding permits a conserved binding geometry in TCR recognition of foreign and self molecular mimics.",
  "journal": "Journal of immunology (Baltimore, Md. : 1950)",
  "year": 2011,
  "authors": "Borbulevych OY, Piepenbrink KH, Baker BM."
 },
 "executive_summary": "The \u03b1\u03b2 TCR A6 recognizes both the foreign antigen Tax from human T cell leukemia virus-1 (HTLV-1) and a self peptide from the neuronal protein HuD, both presented by HLA-A2. Although the HuD and Tax epitopes are structural mimics rather than perfect matches, A6 engages both peptides using an identical, conserved binding mode despite requiring conformational adjustments in the peptide and MHC for HuD recognition. This molecular mimicry between viral and self antigens provides insight into how cross-reactivity can occur and may explain the development of HTLV-1-associated myelopathy/tropical spastic paraparesis as an autoimmune complication. The study shows that low stability of the HuD\u2013HLA-A2 complex permits survival of self-reactive T cells bearing this TCR while maintaining affinity levels consistent with negative selection, demonstrating how conformational flexibility in pMHC complexes can enable molecular mimicry-driven autoimmunity.",
 "noncanonical": {
  "flag": false,
  "evidence": ""
 },
