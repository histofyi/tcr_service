 "publication": {
  "pmid": "42190883",
  "doi": "10.1016/j.jsb.2026.108329",
  "title": "Structural basis for TCR recognition of a Rac1 neoantigen arising from anchor residue mutation.",
  "journal": "Journal of structural biology",
  "year": 2026,
  "authors": "Zeng Y, Yang D, Zhao J, Yuan P, Jin H, Liao W, Chen G, Wu D."
 },
 "executive_summary": "T cell receptor (TCR) 5934 recognizes a melanoma neoantigen derived from Rac1 protein with a P29S mutation at an MHC anchor residue, presented by HLA-A2. Unlike typical neoantigens that arise from solvent-exposed mutations, this anchor-residue mutation paradoxically enables HLA-A2 presentation of the mutant Rac1P29S peptide while preventing wild-type peptide binding. The TCR primarily engages a non-mutated C-terminal threonine (P8) rather than the mutated N-terminal serine (P2), revealing an unconventional mechanism of neoantigen recognition that does not depend on direct TCR contact with the mutated residue itself. This structural finding challenges the common paradigm that TCRs must focus on the mutation to distinguish neoantigens from self, and provides insights applicable to rational design of TCR-based cancer immunotherapies targeting anchor-residue neoantigens.",
 "noncanonical": {
  "flag": false,
  "evidence": ""
 },
