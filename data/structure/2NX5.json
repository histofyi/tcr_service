 "publication": {
  "pmid": "17259989",
  "doi": "10.1038/ni1432",
  "title": "A T cell receptor flattens a bulged antigenic peptide presented by a major histocompatibility complex class I molecule.",
  "journal": "Nature immunology",
  "year": 2007,
  "authors": "Tynan FE, Reid HH, Kjer-Nielsen L, Miles JJ, Wilce MC, Kostenko L, Borg NA, Williamson NA, Beddoe T, Purcell AW, Burrows SR, McCluskey J, Rossjohn J."
 },
 "executive_summary": "The study examined the ELS4 T cell receptor bound to an Epstein-Barr virus peptide presented by HLA-B*3501, capturing an unusually rigid interaction in which the TCR physically flattened a bulged peptide structure. Unlike the typical adaptive plasticity of TCR-pMHCI recognition, this TCR employed a \"bulldozing\" mechanism that crumpled the antigenic peptide to create a flatter binding surface, thereby maximizing critical contacts with the MHC class I molecule itself rather than accommodating the peptide's intrinsic shape. This finding challenges the conventional model of TCR flexibility and suggests that antigen recognition can instead rely on TCR-imposed constraints that reshape the peptide backbone. The work is significant for understanding how TCRs achieve MHC-restricted recognition and has implications for viral immunity, since the remodeling of pathogen-derived peptides by the TCR may be a generalizable strategy for robust antigen detection.",
 "noncanonical": {
  "flag": true,
  "evidence": "2NX5: \"This complex was atypical of previously characterized TCR-pMHCI interactions in that a rigid face of the TCR crumpled the bulged antigenic determinant\""
 },
