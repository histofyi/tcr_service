 "publication": {
  "pmid": "23569211",
  "doi": "10.1074/jbc.m112.447185",
  "title": "Highly divergent T-cell receptor binding modes underlie specific recognition of a bulged viral peptide bound to a human leukocyte antigen class I molecule.",
  "journal": "The Journal of biological chemistry",
  "year": 2013,
  "authors": "Liu YC, Miles JJ, Neller MA, Gostick E, Price DA, Purcell AW, McCluskey J, Burrows SR, Rossjohn J, Gras S."
 },
 "executive_summary": "Three distinct human TCRs (CA5, SB27, and SB47) were characterized in complex with HLA-B*35:08 presenting a super-bulged viral peptide (LPEPLPQGQLTAY), revealing fundamentally different recognition strategies for the same pMHC-I ligand. While CA5 and SB27 TCRs engaged the peptide and central HLA regions with limited contacts, the SB47 TCR adopted a completely distinct mechanism, bypassing the bulged peptide entirely and binding to the extreme N-terminal end of HLA-B*35:08 through an atypical footprint including previously unobserved TCR contact sites. These divergent binding modes, despite targeting identical antigen-presenting surfaces, highlight how TCR recognition of bulged peptides depends on unpredictable structural strategies and emphasize the plasticity of the TCR-pMHC interface. The finding that the same HLA-peptide combination can be recognized via multiple alternative docking angles helps explain both the specificity and cross-reactivity patterns observed among TCRs, with implications for understanding how the T-cell repertoire generates recognition diversity for unconventional peptide presentations.",
 "noncanonical": {
  "flag": true,
  "evidence": "4JRY: \"the SB47 TCR engaged HLA-B*35:08(LPEP) using a completely distinct binding mechanism, namely 'bypassing' the bulged peptide ... including the adoption of atypical footprints on the MHC-I\""
 },
