 "publication": {
  "pmid": "36424374",
  "doi": "10.1038/s41467-022-34896-0",
  "title": "A class-mismatched TCR bypasses MHC restriction via an unorthodox but fully functional binding geometry.",
  "journal": "Nature communications",
  "year": 2022,
  "authors": "Singh NK, Alonso JA, Devlin JR, Keller GLJ, Gray GI, Chiranjivi AK, Foote SG, Landau LM, Arbuiso AG, Weiss LI, Rosenberg AM, Hellman LM, Nishimura MI, Baker BM."
 },
 "executive_summary": "TIL1383I is a class-mismatched TCR derived from a CD4+ T cell that unexpectedly recognizes the tyrosinase tumor antigen presented by HLA-A2, a class I MHC molecule, with full functional competence including TCR signaling, antigen specificity, and CD8 co-receptor engagement. The TCR achieves this through a highly atypical binding geometry, particularly via an exceptionally long CDR3\u03b2 loop that consolidates functions normally distributed across multiple hypervariable and germline regions in conventional TCRs. This finding reveals that MHC restriction\u2014the traditional requirement that CD4+ TCRs bind class II and CD8+ TCRs bind class I\u2014can be mechanistically bypassed through unconventional structural solutions while preserving normal immune function. These results expand the known repertoire of viable TCR binding modes and provide mechanistic insight into MHC restriction determinants, with direct implications for TCR engineering and selection in cancer immunotherapy.",
 "noncanonical": {
  "flag": true,
  "evidence": "7RK7: \"TIL1383I binds this class I target with a highly atypical geometry\" / \"an unorthodox but fully functional binding geometry\""
 },
