  "doi": "10.1073/pnas.1207896109",
  "title": "Structural features underlying T-cell receptor sensitivity to concealed MHC class I micropolymorphisms.",
  "journal": "Proceedings of the National Academy of Sciences of the United States of America",
  "year": 2012,
  "authors": "Stewart-Jones GB, Simpson P, van der Merwe PA, Easterbrook P, McMichael AJ, Rowland-Jones SL, Jones EY, Gillespie GM."
