 "publication": {
  "pmid": null,
  "doi": "10.1101/2021.06.06.447276",
  "title": "Cross-reactive TCR with alloreactivity for immunodominant HIV-1 epitope Gag TL9 with enhanced control of viral infection",
  "journal": "Biorxiv",
  "year": 2021,
  "authors": "Liu Y, San D, Yin L."
 },
 "executive_summary": "This study investigates a cross-reactive TCR that recognizes the immunodominant HIV-1 Gag TL9 epitope presented by two structurally distinct HLA B*81:01 and B*42:01 alleles, which are members of the B7 supertype. The key structural finding is that a T18A mutation in the TCR induces a conformational switch in the TL9 peptide when bound to B*42:01, enabling it to adopt the conformation it naturally adopts in B*81:01, thereby explaining how a single TCR achieves dual recognition despite radically different p-MHC surfaces. The TCR's unique CDR3\u03b2 docking mode, which engages the MHC rather than the peptide ligand, confers enhanced peptide tolerance and allows the TCR to accommodate escape mutations while maintaining high affinity for both wild-type and mutant TL9 variants. This alloreactive phenotype is functionally advantageous for viral control, as the TCR's ability to tolerate peptide variation may improve T-cell responses against evolving HIV-1 escape mutants and inform rational TCR engineering strategies.",
 "noncanonical": {
  "flag": false,
  "evidence": ""
 },
