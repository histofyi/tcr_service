 "publication": {
  "pmid": "27238970",
  "doi": "10.1016/j.str.2016.04.011",
  "title": "An Engineered Switch in T Cell Receptor Specificity Leads to an Unusual but Functional Binding Geometry.",
  "journal": "Structure (London, England : 1993)",
  "year": 2016,
  "authors": "Harris DT, Singh NK, Cai Q, Smith SN, Vander Kooi C, Procko E, Kranz DM, Baker BM."
 },
 "executive_summary": "This study examined a parental TCR and its engineered variant to understand how TCR specificity is determined, focusing on how molecular evolution switched the receptor's peptide recognition while maintaining functional signaling. The engineered TCR achieved altered specificity through a dramatically different binding geometry to its pMHC ligand, with the molecular basis distributed across contact and non-contact residues in both germline and hypervariable regions, including disruption of canonical TCR-MHC interaction modes. The findings reveal that TCR specificity emerges from the coordinated action of multiple sites throughout the interface, rather than a few dominant determinants, and that functional binding and signaling can be preserved even under unusual binding geometries. This work has direct implications for rational engineering of therapeutic TCRs with novel specificities, demonstrating that successful redesign of TCR recognition is achievable while maintaining biological function.",
 "noncanonical": {
  "flag": false,
  "evidence": ""
 },
