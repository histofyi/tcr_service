 "publication": {
  "pmid": "28945243",
  "doi": "10.1038/ni.3850",
  "title": "Germline bias dictates cross-serotype reactivity in a common dengue-virus-specific CD8+ T cell response.",
  "journal": "Nature immunology",
  "year": 2017,
  "authors": "Culshaw A, Ladell K, Gras S, McLaren JE, Miners KL, Farenc C, van den Heuvel H, Gostick E, Dejnirattisai W, Wangteeraprasert A, Duangchinda T, Chotiyarnwong P, Limpitikul W, Vasanawathana S, Malasit P, Dong T, Rossjohn J, Mongkolsapaya J, Price DA, Screaton GR."
 },
 "executive_summary": "Dengue virus-specific CD8+ T cells restricted by HLA-A*11:01 and targeting variants of the NS3 nonstructural protein epitope NS3133 across DENV1, DENV3, and DENV4 were predominantly composed of TCRs bearing the TRBV11-2 \u03b2-chain variable region, whereas the DENV2 variant repertoire lacked these clonotypes. Crystal structures and mutagenesis of representative TRBV11-2+ TCRs revealed that cross-serotype reactivity is driven by germline-encoded residues in the TCR \u03b2-chain CDR2 region making critical contacts with serotype-specific peptide positions, enabling an innate-like mode of recognition that bypasses the need for extensive affinity maturation. This finding explains how a single TCR gene segment can recognize multiple dengue serotypes through a germline-biased mechanism, with direct implications for secondary dengue infection outcomes and the heightened risk of dengue hemorrhagic fever when exposure to heterologous serotypes occurs sequentially.",
 "noncanonical": {
