 "publication": {
  "pmid": "16186824",
  "doi": "10.1038/ni1257",
  "title": "T cell receptor recognition of a 'super-bulged' major histocompatibility complex class I-bound peptide.",
  "journal": "Nature immunology",
  "year": 2005,
  "authors": "Tynan FE, Burrows SR, Buckle AM, Clements CS, Borg NA, Miles JJ, Beddoe T, Whisstock JC, Wilce MC, Silins SL, Burrows JM, Kjer-Nielsen L, Kostenko L, Purcell AW, McCluskey J, Rossjohn J."
 },
 "executive_summary": "This study examined TCR recognition of an unusually long 13-amino-acid peptide presented by HLA-B*3508, addressing how T cells can recognize extended epitopes that form a central bulge in the peptide-binding groove despite the structural constraints of MHC restriction. The crystal structure revealed that the TCR made predominantly peptide-centered contacts rather than the typical MHC-focused interactions, with the TCR able to adopt two distinct orientations while swiveling on the rigid bulged peptide core and making only minimal contacts with the MHC class I molecule itself. This finding is significant because it demonstrates that TCR recognition is remarkably adaptable\u2014capable of accommodating conformationally atypical peptide presentations\u2014while simultaneously establishing a minimal \"generic footprint\" that defines MHC restriction, revealing how T cells maintain specificity even when engaging non-canonical epitope geometries. The work has implications for understanding how the immune system responds to naturally occurring unusually long peptides and highlights structural principles relevant to TCR engineering and cross-reactive recognition.",
 "noncanonical": {
  "flag": true,
  "evidence": "2AK4: \"This complex was atypical of TCR-peptide-MHC class I interactions, being dominated at the interface by peptide-mediated interactions\""
 },
