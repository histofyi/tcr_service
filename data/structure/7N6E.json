 "publication": {
  "pmid": "34384783",
  "doi": "10.1016/j.jbc.2021.101065",
  "title": "Structural basis of biased T cell receptor recognition of an immunodominant HLA-A2 epitope of the SARS-CoV-2 spike protein.",
  "journal": "The Journal of biological chemistry",
  "year": 2021,
  "authors": "Chaurasia P, Nguyen THO, Rowntree LC, Juno JA, Wheatley AK, Kent SJ, Kedzierska K, Rossjohn J, Petersen J."
 },
 "executive_summary": "CD8+ T cells recognize the immunodominant S269-277 peptide from SARS-CoV-2 spike protein presented by HLA-A*02:01, with a striking bias toward TCRs expressing the TRAV12 gene segment. Crystal and cryo-EM structures of TRAV12+ TCRs bound to the HLA-A2/S269-277 complex reveal extensive contacts across the full length of the peptide, explaining both the dominance of this TCR segment and the sensitivity of these T cells to sequence variation. Despite this immunodominance during SARS-CoV-2 infection, TRAV12+ TCRs show poor cross-reactivity with analogous peptides from viral variants and related coronaviruses, as demonstrated by surface plasmon resonance and tetramer binding studies. This structural framework elucidates how a highly focused TCR repertoire can achieve dominant immunity against a single epitope while remaining poorly equipped to recognize antigenically similar variants, with implications for vaccine design and understanding the robustness of CD8+ T cell responses to evolving SARS-CoV-2 strains.",
 "noncanonical": {
