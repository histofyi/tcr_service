 "publication": {
  "pmid": "22140258",
  "doi": "10.4049/jimmunol.1102686",
  "title": "A structural basis for varied \u03b1\u03b2 TCR usage against an immunodominant EBV antigen restricted to a HLA-B8 molecule.",
  "journal": "Journal of immunology (Baltimore, Md. : 1950)",
  "year": 2012,
  "authors": "Gras S, Wilmann PG, Chen Z, Halim H, Liu YC, Kjer-Nielsen L, Purcell AW, Burrows SR, McCluskey J, Rossjohn J."
 },
 "executive_summary": "This study examined how three distinct \u03b1\u03b2 TCRs, despite varying gene usage and immunodominance hierarchies, recognize the same EBV epitope FLRGRAYGL presented by HLA-B8. Structural and biophysical analysis revealed that the three TCRs exhibit different fine specificities for the viral antigen, with the peptide itself\u2014rather than HLA contacts\u2014serving as the primary energetic driver of binding, while adjacent HLA-based interactions tune specificity requirements. The findings demonstrate that the viral peptide acts as the dominant \"glue\" holding the TCR-pMHC complex together, with TCR-MHC contacts playing a supporting role. This work provides molecular insight into how a polyclonal T cell response can target the same immunodominant viral epitope through diverse TCR usage while maintaining differential engagement of the antigen, relevant for understanding both natural EBV immunity and potential TCR engineering strategies for viral infections.",
 "noncanonical": {
  "flag": false,
  "evidence": ""
 },
