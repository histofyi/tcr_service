 "publication": {
  "pmid": "18275829",
  "doi": "10.1016/j.immuni.2007.12.018",
  "title": "The structural dynamics and energetics of an immunodominant T cell receptor are programmed by its Vbeta domain.",
  "journal": "Immunity",
  "year": 2008,
  "authors": "Ishizuka J, Stewart-Jones GB, van der Merwe A, Bell JI, McMichael AJ, Jones EY."
 },
 "executive_summary": "The study characterizes the Vbeta17:Valpha10.2 JM22 TCR binding to the influenza matrix peptide (58-66) presented by HLA-A*0201, a public TCR clonotype frequently observed in influenza-infected individuals. Through kinetic, thermodynamic, and structural analyses, the authors identified a binding hotspot within the Vbeta domain, where germline-encoded residues in CDR1, CDR2, and CDR3 drive strong HLA-A2-flu recognition. These structural features explain why Vbeta17-containing TCRs are enriched in the naive repertoire and readily selected during immune responses to influenza. The findings demonstrate how conserved germline sequences can bias TCR usage toward immunodominant clonotypes, providing molecular insight into the paradox of public TCR selection despite the vast diversity of the TCR repertoire.",
 "noncanonical": {
  "flag": false,
  "evidence": ""
 },
