 "publication": {
  "pmid": "40154610",
  "doi": "10.1016/j.jbc.2025.108445",
  "title": "Determining T-cell receptor binding orientation and Peptide-HLA interactions using cross-linking mass spectrometry.",
  "journal": "The Journal of biological chemistry",
  "year": 2025,
  "authors": "Powell T, Karuppiah V, Shaikh SA, Pengelly R, Mai N, Barnbrook K, Sharma A, Harper S, Ebner M, Creese AJ."
 },
 "executive_summary": "This study develops a cross-linking mass spectrometry method to determine TCR binding orientation to peptide-HLA complexes, validating the approach against crystal structures of two TCR\u2013pHLA systems. The key finding is that XL-MS/MS can distinguish between canonical and reverse TCR docking orientations by mapping cross-linking sites to specific residues and identifying molecular interaction footprints. Since canonical binding geometry is essential for T cell activation while reverse-oriented TCRs are non-functional, rapid characterization of binding orientation is critical for understanding TCR specificity in immune response to pathogens and cancer surveillance. The method offers a faster and simpler alternative to structural biology techniques for assessing TCR\u2013pHLA interactions, potentially accelerating research on T cell recognition and TCR engineering applications.",
 "noncanonical": {
  "flag": true,
  "evidence": "9GV7: \"the crystal structure revealed TCR-E bound to its cognate pHLA in the reverse orientation. This non-canonical TCR had a crossing angle of 192.9\u00b0\""
 },
