  "doi": "10.1016/j.ymthe.2018.12.010",
  "title": "Improving T Cell Receptor On-Target Specificity via Structure-Guided Design.",
  "journal": "Molecular therapy : the journal of the American Society of Gene Therapy",
  "year": 2019,
  "authors": "Hellman LM, Foley KC, Singh NK, Alonso JA, Riley TP, Devlin JR, Ayres CM, Keller GLJ, Zhang Y, Vander Kooi CW, Nishimura MI, Baker BM."
