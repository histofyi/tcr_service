 "publication": {
  "pmid": "39002680",
  "doi": "10.1016/j.jbc.2024.107563",
  "title": "Structural insights into immune escape at killer T cell epitope by SARS-CoV-2 Spike Y453F variants.",
  "journal": "The Journal of biological chemistry",
  "year": 2024,
  "authors": "Deng S, Xu Z, Wang M, Hu J, Liu Z, Zhu F, Zheng P, Kombe Kombe AJ, Zhang H, Wu S, Jin T."
 },
 "executive_summary": "This structural study examined how four natural mutations within the HLA-A24\u2013restricted SARS-CoV-2 Spike NYN epitope (residues 448\u2013456) affect CD8+ T cell recognition, focusing on variants N450K, L452Q, L452R, and Y453F that have emerged in circulating viral lineages. Although these mutations minimally disrupted HLA presentation, the Y453F and L452R substitutions substantially reduced binding affinity between the peptide-HLA complex and NYN-specific TCRs derived from COVID-19 patients, demonstrating viral immune escape at the molecular level. Crystal structures of HLA-A24 bound to the Y453F mutant peptide and a ternary complex with the public TCR and wild-type NYN-HLA-A24 revealed that the Y453F mutation abrogates stable TCR engagement despite preserved HLA loading, attributable to diminished peptide-TCR contacts. The findings underscore how mutations within CD8+ T cell epitopes can erode cellular immunity without disrupting antigen presentation, revealing a key mechanism driving SARS-CoV-2 evolution and highlighting the vulnerability of TCR-based immunity to variant-mediated escape.",
 "noncanonical": {
