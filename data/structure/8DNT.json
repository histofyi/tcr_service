 "publication": {
  "pmid": "37872153",
  "doi": "10.1038/s41467-023-42430-z",
  "title": "SARS-CoV-2 infection establishes a stable and age-independent CD8<sup>+</sup> T cell response against a dominant nucleocapsid epitope using restricted T cell receptors.",
  "journal": "Nature communications",
  "year": 2023,
  "authors": "Choy C, Chen J, Li J, Gallagher DT, Lu J, Wu D, Zou A, Hemani H, Baptiste BA, Wichmann E, Yang Q, Ciffelo J, Yin R, McKelvy J, Melvin D, Wallace T, Dunn C, Nguyen C, Chia CW, Fan J, Ruffolo J, Zukley L, Shi G, Amano T, An Y, Meirelles O, Wu WW, Chou CK, Shen RF, Willis RA, Ko MSH, Liu YT, De S, Pierce BG, Ferrucci L, Egan J, Mariuzza R, Weng NP."
 },
 "executive_summary": "SARS-CoV-2 infection establishes a stable CD8+ T cell response targeting a dominant nucleocapsid epitope (N222-230, LLLDRLNQL) presented on HLA-A2, characterized by marked restriction in TCR usage\u2014specifically TRAV12-2 with limited CDR3\u03b1 motifs as revealed by structural analysis of the TCR-peptide-MHC complex. The LLL epitope elicits the strongest proliferative response across both convalescent and uninfected donors, with N-specific CD8+ T cell frequencies and activation capacity remaining stable over one year post-infection. This restricted TCR repertoire targeting a non-spike viral protein is notable because it suggests that even immunodominant epitopes from structural proteins can drive focused T cell responses with constrained clonal composition, which has implications for understanding CD8+ T cell immunity to SARS-CoV-2 and designing T cell\u2013based vaccines or therapeutics that account for this natural TCR bias.",
 "noncanonical": {
  "flag": false,
  "evidence": ""
 },
